# =============================================================================
# NFTopia Backend — Production Environment Template
# =============================================================================
#
# USAGE:
#   cp .env.production.template .env.production
#   # Edit .env.production with your production values.
#   # NEVER commit .env.production to version control.
#
# IMPORTANT:
#   This file contains ONLY non-secret configuration.
#   All credentials (passwords, JWT secrets, API keys, Stellar operator secret)
#   MUST be provisioned as Docker secrets via `docker secret create`.
#   See docker-compose.prod.yml header for secret provisioning commands.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
GRAPHQL_PORT=3001
GRAPHQL_PLAYGROUND_ENABLED=false
GRAPHQL_INTROSPECTION_ENABLED=false

# Structured JSON logging — set to warn or error in production
LOG_LEVEL=warn
# Fraction of requests to log (0.0–1.0). Lower in high-traffic environments.
LOG_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins (no trailing slash)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://nftopia.com,https://app.nftopia.com

# ---------------------------------------------------------------------------
# Database — credentials are injected via Docker secret (nftopia_db_password)
# ---------------------------------------------------------------------------
DB_USER=nftopia_prod
DB_NAME=nftopia_production
# DATABASE_URL is assembled by docker-compose.prod.yml using DB_USER / DB_NAME.
# Do NOT set DB_PASSWORD here — it is read from the Docker secret at runtime.

# ---------------------------------------------------------------------------
# Redis — password is injected via Docker secret (nftopia_redis_password)
# ---------------------------------------------------------------------------
REDIS_DB=0
CACHE_TTL=300

# ---------------------------------------------------------------------------
# JWT — secret is injected via Docker secret (nftopia_jwt_secret)
# ---------------------------------------------------------------------------
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ---------------------------------------------------------------------------
# Stellar / Soroban
# ---------------------------------------------------------------------------
# Use the Mainnet RPC endpoint in production.
SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com
STELLAR_NETWORK=mainnet

# Replace with deployed mainnet contract IDs.
COLLECTION_FACTORY_CONTRACT_ID=CHANGE_ME
TRANSACTION_CONTRACT_ID=CHANGE_ME
MARKETPLACE_SETTLEMENT_CONTRACT_ID=CHANGE_ME
CONTRACT_TRANSACTION_TIMEOUT=60
ENABLE_ONCHAIN_SETTLEMENT=true

TRANSACTION_TIMEOUT_SECONDS=60
SOROBAN_RPC_MAX_RETRIES=3
SOROBAN_RPC_RETRY_DELAY_MS=1000
SOROBAN_RPC_RETRY_BACKOFF_MULTIPLIER=2
SOROBAN_RPC_RETRY_MAX_DELAY_MS=30000

# Public key only — the secret is supplied via Docker secret (nftopia_stellar_operator_secret)
STELLAR_OPERATOR_PUBLIC_KEY=G_CHANGE_ME

# ---------------------------------------------------------------------------
# IPFS / Pinata — JWT is injected via Docker secret (nftopia_pinata_jwt)
# ---------------------------------------------------------------------------
IPFS_PROVIDER=pinata
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
IPFS_MAX_FILE_SIZE_BYTES=52428800
IPFS_RETRY_ATTEMPTS=2
IPFS_RETRY_BACKOFF_MS=250

# ---------------------------------------------------------------------------
# Arweave
# ---------------------------------------------------------------------------
ARWEAVE_GATEWAY_URL=https://arweave.net
ARWEAVE_HOST=arweave.net
ARWEAVE_PORT=443
ARWEAVE_PROTOCOL=https
ARWEAVE_MAX_FILE_SIZE_BYTES=104857600
ARWEAVE_RETRY_ATTEMPTS=2
ARWEAVE_RETRY_BACKOFF_MS=350
STORAGE_FALLBACK_ENABLED=true

# ---------------------------------------------------------------------------
# Malware Scanning (ClamAV)
# ---------------------------------------------------------------------------
MALWARE_SCAN_ENABLED=true
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
SCAN_TIMEOUT_MS=60000
SCAN_RETRY_ATTEMPTS=3
SCAN_RETRY_BACKOFF_MS=500
SCAN_ASYNC_THRESHOLD_BYTES=20971520
SCAN_FAIL_CLOSED=true
SCAN_RESCAN_BATCH_SIZE=25
SCAN_RESCAN_STALE_AFTER_MS=604800000

# ---------------------------------------------------------------------------
# Meilisearch — master key is injected via Docker secret (nftopia_meilisearch_master_key)
# ---------------------------------------------------------------------------
MEILISEARCH_LOG_LEVEL=WARN
